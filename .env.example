# ByteBid - Environment Configuration
# Copy file ini menjadi .env dan sesuaikan

# ── Flask ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=bytebid-secret-key-2026

# ── Database (XAMPP MySQL) ────────────────────────────
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bytebid

# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=bytebid-jwt-secret-2026

# ── Email (kosongkan kalau dev tanpa email) ──────────
# Untuk Gmail: pakai App Password, bukan password biasa
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@bytebid.id
